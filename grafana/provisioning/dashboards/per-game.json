{
  "uid": "per-game",
  "title": "Per-Game",
  "tags": [
    "bot-manager",
    "observability",
    "per-game"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "weekStart": "",
  "timezone": "",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "30s",
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "game",
        "label": "Game",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(game_info, gameName)",
        "query": {
          "qryType": 1,
          "query": "label_values(game_info, gameName)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "hide": 0,
        "current": {},
        "options": [],
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "gameId",
        "label": "Game ID (resolved)",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(game_info{gameName=\"$game\"}, gameId)",
        "query": {
          "qryType": 1,
          "query": "label_values(game_info{gameName=\"$game\"}, gameId)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "hide": 2,
        "current": {},
        "options": [],
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Bot groups (this game)",
      "description": "Distinct botGroupId count emitting series for the selected game. NOTE (AD-7): series created before the gameId-label rollout lack the gameId label and are excluded by design.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(count by (botGroupId) (bot_messages_total{gameId=\"$gameId\"}))",
          "legendFormat": "groups"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total bots (this game)",
      "description": "Sum of bots across all statuses for the selected game, from bots_by_game_status.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(bots_by_game_status{gameId=\"$gameId\"})",
          "legendFormat": "bots"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "RTP (5m)",
      "description": "Realized RTP for the selected game: sum(rate(bot_winnings))/sum(rate(bot_bet_amount)). 'or vector(0)' renders 0 when the game has no bets yet (AD-7).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.90
              },
              {
                "color": "green",
                "value": 0.97
              }
            ]
          },
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(rate(bot_winnings_total{gameId=\"$gameId\"}[5m])) / sum(rate(bot_bet_amount_total{gameId=\"$gameId\"}[5m]))) or vector(0)",
          "legendFormat": "RTP"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DEAD seconds (last 1h)",
      "description": "Cumulative bot DEAD seconds increase over the last hour for the selected game.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(bot_dead_seconds_total{gameId=\"$gameId\"}[1h]))",
          "legendFormat": "dead seconds (1h)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Bots by status",
      "description": "Live bot count per BotStatus for the selected game (bots_by_game_status). Covers connected (CONNECTION_AUTHENTICATED), reconnecting, dead, disconnected — whichever statuses are live.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "bots_by_game_status{gameId=\"$gameId\"}",
          "legendFormat": "{{status}}"
        }
      ]
    },
